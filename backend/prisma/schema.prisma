generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String                    @id @default(uuid())
  name               String
  email              String                    @unique
  passwordHash       String
  role               Role                      @default(MEMBER)
  isVerified         Boolean                   @default(false)
  isSuspended        Boolean                   @default(false)
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  expertBookings     Booking[]                 @relation("ExpertBookings")
  memberBookings     Booking[]                 @relation("MemberBookings")
  bookmarks          Bookmark[]
  conversations      ConversationParticipant[]
  emailVerifications EmailVerification[]
  organizedEvents    Event[]                   @relation("UserOrganizedEvents")
  eventRegistrations EventRegistration[]
  messages           Message[]
  notifications      Notification[]
  passwordResets     PasswordReset?
  profile            Profile?
  projects           Project[]
  projectInterests   ProjectInterest[]
  refreshTokens      RefreshToken[]
  expertReviews      Review[]                  @relation("ExpertReviews")
  writtenReviews     Review[]                  @relation("ReviewerReviews")

  investorProfile    InvestorProfile?
  investorMatches    Match[]              @relation("InvestorMatches")
  llmInsights        LlmInsight[]         @relation("InvestorInsights")
  @@index([email])
}

model Profile {
  id                 String               @id @default(uuid())
  userId             String               @unique
  bio                String?
  phone              String?
  location           String?
  avatar             String?
  linkedIn           String?
  expertApplicationStatus String?         @default("NONE")  
  expertise          String[]             @default([])
  industries         String[]             @default([])
  certifications     String[]             @default([])
  updatedAt          DateTime             @default(now()) @updatedAt
  hourlyRate         Decimal?
  yearsOfExperience  Int?
  availabilityStatus AvailabilityStatus   @default(AVAILABLE)
  createdAt          DateTime             @default(now())
  avgRating          Float                @default(0)
  reviewCount        Int                  @default(0)
  currency           String?
  companyName        String?
  stage              String?
  settings           Json?
  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  weeklyAvailability WeeklyAvailability[]
}

model EmailVerification {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

model PasswordReset {
  id        String   @id @default(uuid())
  userId    String   @unique
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Project {
  id            String                   @id @default(uuid())
  ownerId       String
  title         String
  tagline       String
  shortDesc     String
  fullDesc      String
  stage         ProjectStage
  industry      String
  technologies  String[]
  fundingSought Decimal?
  currency      String
  location      String?
  status        ProjectStatus            @default(DRAFT)
  visibility    ProjectVisibility        @default(PUBLIC)
  viewCount     Int                      @default(0)
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  featured      Boolean                  @default(false)
  search_vector Unsupported("tsvector")?
  bookmarks     Bookmark[]
  milestones    Milestone[]
  owner         User                     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  documents     ProjectDocument[]
  interests     ProjectInterest[]
  updates       ProjectUpdate[]
  teamMembers   TeamMember[]
  
  aiAssessment       AiAssessment?
matches            Match[]
llmInsights        LlmInsight[]
  @@index([status, industry])
  @@index([status, stage])
  @@index([ownerId])
}

model TeamMember {
  id        String   @id @default(uuid())
  projectId String
  name      String
  role      String
  photo     String?
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Milestone {
  id          String    @id @default(uuid())
  projectId   String
  title       String
  description String
  targetDate  DateTime?
  completedAt DateTime?
  order       Int
  createdAt   DateTime  @default(now())
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectDocument {
  id        String   @id @default(uuid())
  projectId String
  name      String
  fileUrl   String
  fileKey   String
  fileType  String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Bookmark {
  id        String   @id @default(uuid())
  userId    String
  projectId String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
}

model ProjectInterest {
  id        String   @id @default(uuid())
  projectId String
  userId    String
  message   String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model ProjectUpdate {
  id        String   @id @default(uuid())
  projectId String
  content   String
  imageUrl  String?
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Conversation {
  id           String                    @id @default(uuid())
  createdAt    DateTime                  @default(now())
  lastMessageAt DateTime?
  participants ConversationParticipant[]
  messages     Message[]
  
}

model ConversationParticipant {
  id             String       @id @default(uuid())
  conversationId String
  userId         String
  lastReadAt     DateTime?
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  hasAttachment  Boolean      @default(false)
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

model Event {
  id            String              @id @default(uuid())
  title         String
  description   String
  type          EventType
  date          DateTime
  endDate       DateTime?
  location      String?
  virtualLink   String?
  capacity      Int?
  organizerId   String
  hostType      HostType
  coverImage    String?
  status        EventStatus         @default(DRAFT)
  createdAt     DateTime            @default(now())
  organizer     User                @relation("UserOrganizedEvents", fields: [organizerId], references: [id], onDelete: Cascade)
  registrations EventRegistration[]
}

model EventRegistration {
  id      String @id @default(uuid())
  eventId String
  userId  String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model WeeklyAvailability {
  id        String  @id @default(uuid())
  profileId String
  day       Int
  startTime String?
  endTime   String?
  enabled   Boolean @default(true)
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, day])
}

model Booking {
  id              String        @id @default(uuid())
  expertId        String
  memberId        String
  startDateTime   DateTime
  endDateTime     DateTime
  duration        Int
  price           Decimal
  topic           String?
  message         String?
  rejectionReason String?
  meetingType     String?
  meetingLink     String?
  location        String?
  status          BookingStatus @default(PENDING)
  createdAt       DateTime      @default(now())
  expert          User          @relation("ExpertBookings", fields: [expertId], references: [id], onDelete: Cascade)
  member          User          @relation("MemberBookings", fields: [memberId], references: [id], onDelete: Cascade)
  review          Review?

  @@index([expertId, startDateTime])
  @@index([memberId])
  @@index([expertId, status])
  @@index([memberId, status])
}

model Review {
  id             String   @id @default(uuid())
  expertId       String
  reviewerId     String
  consultationId String   @unique
  rating         Int
  comment        String?
  createdAt      DateTime @default(now())
  booking        Booking  @relation(fields: [consultationId], references: [id])
  expert         User     @relation("ExpertReviews", fields: [expertId], references: [id])
  reviewer       User     @relation("ReviewerReviews", fields: [reviewerId], references: [id])
}


model AiAssessment {
  id                          String        @id @default(uuid())
  projectId                   String        @unique
  trlScore                    Int
  trlConfidence               TrlConfidence
  trlBreakdown                Json
  irScore                     Int
  irBreakdown                 Json
  recommendations             String[]
  executiveSummary            String?
  strengthsNarrative          String?
  risksNarrative              String?
  marketOpportunityNarrative  String?
  llmModel                    String?
  assessedAt                  DateTime      @default(now())
  version                     Int           @default(1)
  project                     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model LlmInsight {
  id         String         @id @default(uuid())
  investorId String?
  projectId  String
  type       LlmInsightType
  content    Json
  inputHash  String
  createdAt  DateTime       @default(now())
  investor   User?          @relation("InvestorInsights", fields: [investorId], references: [id], onDelete: Cascade)
  project    Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([investorId, projectId, type])
}

model InvestorProfile {
  id               String        @id @default(uuid())
  userId           String        @unique
  industries       String[]      @default([])
  technologies     String[]      @default([])
  stages           String[]      @default([])
  fundingMin       Decimal?
  fundingMax       Decimal?
  currency         String?
  geographicPrefs  String[]      @default([])
  riskTolerance    RiskTolerance @default(MEDIUM)
  dealStructures   String[]      @default([])
  mustHaves        Json?
  exclusions       Json?
  investmentThesis String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Match {
  id                     String      @id @default(uuid())
  investorId             String
  projectId              String
  matchScore             Int
  reasoning              Json?
  categoryScores         Json?
  thesisAlignmentSummary String?
  status                 MatchStatus @default(SUGGESTED)
  createdAt              DateTime    @default(now())
  investor               User        @relation("InvestorMatches", fields: [investorId], references: [id], onDelete: Cascade)
  project                Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([investorId, projectId])
  @@index([investorId, status])
}


enum AvailabilityStatus {
  AVAILABLE
  BUSY
  UNAVAILABLE
}

enum Role {
  MEMBER
  EXPERT
  STARTUP
  INVESTOR
  ADMIN
}

enum ProjectStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum ProjectVisibility {
  PUBLIC
  CONNECTIONS
}

enum ProjectStage {
  IDEA
  PROTOTYPE
  MVP
  GROWTH
  SCALING
}

enum NotificationType {
  MESSAGE
  EVENT
  PROJECT_UPDATE
  SYSTEM
  BOOKING
}

enum EventType {
  CONFERENCE
  NETWORKING
  PITCH_DAY
  WORKSHOP
}

enum HostType {
  ADMIN
  EXPERT
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
}

enum BookingStatus {
  PENDING_PAYMENT
  PENDING
  ACCEPTED
  DECLINED
  COMPLETED
  CANCELLED
}



enum TrlConfidence {
  HIGH
  MEDIUM
  LOW
}

enum LlmInsightType {
  THESIS_ALIGNMENT
  PITCH_ANALYSIS
  DD_SUMMARY
  DEAL_BRIEF
}

enum RiskTolerance {
  LOW
  MEDIUM
  HIGH
}

enum MatchStatus {
  SUGGESTED
  VIEWED
  CONTACTED
  DISMISSED
}